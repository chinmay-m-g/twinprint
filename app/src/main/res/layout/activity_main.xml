<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E88E5"
        android:elevation="6dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnEditFileName"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="TwinPrint PDF Studio"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

            <ImageButton
                android:id="@+id/btnEditFileName"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_edit"
                android:visibility="gone"
                app:tint="#FFFFFF" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- 1. HOME PAGE -->
    <RelativeLayout
        android:id="@+id/viewHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:padding="40dp"
            android:text="Welcome to TwinPrint!\n\nOpen a PDF or create a new one from your images."
            android:textColor="#B0BEC5"
            android:textSize="18sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRecentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="RECENT PDFs"
            android:textColor="#546E7A"
            android:textSize="14sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/homeBottomContainer"
            android:layout_below="@id/tvRecentLabel">

            <LinearLayout
                android:id="@+id/llRecentItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />
        </ScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/homeBottomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenPdf"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:layout_weight="1"
                    android:text="OPEN PDF"
                    android:letterSpacing="0.05"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconPadding="8dp"
                    android:backgroundTint="#1E88E5"
                    android:textColor="#FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreatePdf"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_margin="6dp"
                    android:layout_weight="1"
                    android:text="CREATE"
                    android:letterSpacing="0.05"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_add"
                    app:iconPadding="8dp"
                    android:backgroundTint="#43A047"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <!-- 2. PDF VIEWER PAGE -->
    <LinearLayout
        android:id="@+id/viewViewer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPdfPages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#263238" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#99000000"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvPageIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="1 / 1"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainSave"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="SAVE PDF"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_save"
                    android:backgroundTint="#43A047" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainPrint"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="PRINT"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_set_as"
                    android:backgroundTint="#1E88E5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- 3. MANAGE PAGES UI (Reorder) -->
    <LinearLayout
        android:id="@+id/viewManageMerge"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEditPages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiscardMerge"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="CANCEL"
                    android:textColor="#757575"
                    app:cornerRadius="16dp"
                    app:strokeColor="#BDBDBD" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmMerge"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1.5"
                    android:text="GENERATE PDF"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_directions"
                    android:backgroundTint="#1E88E5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- 4. PRINT OPTIONS OVERLAY -->
    <RelativeLayout
        android:id="@+id/viewPrintOptions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:text="Choose Print Mode"
                    android:textColor="#1E88E5"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptSingle"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:text="Single Sided Print"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptTwoSided"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="20dp"
                    android:text="Two Sided Print"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    android:backgroundTint="#1E88E5" />

                <TextView
                    android:id="@+id/tvCancelOptions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:padding="12dp"
                    android:text="CANCEL"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <!-- 5. DUPLEX PAGE -->
    <LinearLayout
        android:id="@+id/viewDuplex"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvDuplexInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="Double Sided Printing"
            android:textColor="#1E88E5"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDuplexPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            android:background="#ECEFF1"
            android:padding="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="FLIP THE STACK NOW"
                    android:textColor="#1565C0"
                    android:fontFamily="sans-serif-black" />

                <ProgressBar
                    android:id="@+id/pbTimer"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="10" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStep1Even"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="STEP 1: EVENS"
                app:cornerRadius="16dp"
                android:backgroundTint="#FF9800" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStep2Odd"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:enabled="false"
                android:text="STEP 2: ODDS"
                app:cornerRadius="16dp"
                android:backgroundTint="#43A047" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackFromDuplex"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="EXIT PRINTING"
            android:textColor="#757575" />
    </LinearLayout>

    <!-- 6. AD OVERLAY -->
    <RelativeLayout
        android:id="@+id/viewAd"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAdLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:text="ADVERTISEMENT"
            android:textColor="#B0BEC5"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPrintingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvAdLabel"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Printing in progress...\nKeep the app open"
            android:textColor="#1E88E5"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/tvAdTimer"
            android:layout_below="@id/tvPrintingStatus"
            android:layout_margin="48dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_launcher_background" />

        <TextView
            android:id="@+id/tvAdTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="48dp"
            android:text="Closing in 30s..."
            android:textColor="#1E88E5"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black" />
    </RelativeLayout>

    <!-- 7. CREATE PDF OPTIONS OVERLAY -->
    <RelativeLayout
        android:id="@+id/viewCreateOptions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="Create New PDF"
                    android:textColor="#43A047"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptGallery"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:text="Choose from Gallery"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_gallery"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    android:textColor="#43A047" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptCamera"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="20dp"
                    android:text="Capture with Camera"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    android:backgroundTint="#43A047" />

                <TextView
                    android:id="@+id/tvCancelCreate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:padding="12dp"
                    android:text="CANCEL"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

</RelativeLayout>
